<!DOCTYPE html>
<html>
<head>
  <title>Signup | Wanderlust</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      height: 100vh;
      font-family: 'Segoe UI', sans-serif;
    }

    .container-fluid {
      height: 100vh;
    }

    /* 🔥 LEFT SIDE (PREMIUM GRADIENT) */
    .left-side {
      background: linear-gradient(135deg, #1e1e9a, #4b2bd6, #6a11cb);
      color: white;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .left-side h1 {
      font-size: 3rem;
      font-weight: bold;
      text-shadow: 0 0 15px rgba(255,255,255,0.4);
    }

    .left-side p {
      margin-top: 10px;
      opacity: 0.9;
    }

    /* 🔥 RIGHT SIDE */
    .right-side {
      display: flex;
      justify-content: center;
      align-items: center;
      background: #f8f9fa;
    }

    .form-box {
      width: 350px;
      padding: 30px;
      border-radius: 10px;
      background: white;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .form-box h3 {
      font-weight: bold;
      text-align: center;
      margin-bottom: 20px;
    }

    .form-control {
      border-radius: 8px;
      padding: 10px;
    }

    /* 🔥 BUTTON */
    .btn-custom {
      background: linear-gradient(135deg, #6a11cb, #2575fc);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 10px;
      transition: 0.3s;
    }

    .btn-custom:hover {
      transform: scale(1.05);
      background: linear-gradient(135deg, #5a0fc8, #1f65e0);
    }

    .login-link {
      text-align: center;
      margin-top: 15px;
    }

    .login-link a {
      text-decoration: none;
      color: #6a11cb;
      font-weight: 500;
    }

  </style>
</head>

<body>

<div class="container-fluid">
  <div class="row h-100">

    <!-- 🔥 LEFT SIDE -->
    <div class="col-md-6 left-side">
      <h1>Get Started</h1>
      <p>Already have an account?</p>
      <a href="/login" class="btn btn-outline-light mt-2">Login</a>
    </div>

    <!-- 🔥 RIGHT SIDE -->
    <div class="col-md-6 right-side">

      <div class="form-box">
        <h3>Create Account</h3>

        <form method="POST" action="/signup">

          <div class="mb-3">
            <input class="form-control" name="username" placeholder="Username" required>
          </div>

          <div class="mb-3">
            <input class="form-control" type="password" name="password" placeholder="Password" required>
          </div>

          <button class="btn btn-custom w-100">Sign Up</button>

        </form>

        <div class="login-link">
          Already have an account? 
          <a href="/login">Login</a>
        </div>

      </div>

    </div>

  </div>
</div>

</body>
</html>