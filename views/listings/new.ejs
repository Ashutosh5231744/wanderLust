<% layout('layouts/boilerplate') %>

<div class="container mt-4">
  <h3>Create New Listing</h3>

  <form method="POST" action="/listings">

    <div class="mb-3">
      <input 
        class="form-control" 
        name="listing[title]" 
        placeholder="Title" 
        required
      >
    </div>

    <div class="mb-3">
      <textarea 
        class="form-control" 
        name="listing[description]" 
        placeholder="Description" 
        required
      ></textarea>
    </div>

    <!-- 🔥 IMAGE URL INPUT (SAFE) -->
    <div class="mb-3">
      <input 
        class="form-control" 
        name="listing[image]" 
        placeholder="Paste Image URL here"
        required
      >
    </div>

    <div class="mb-3">
      <input 
        class="form-control" 
        type="number" 
        name="listing[price]" 
        placeholder="Price" 
        required
      >
    </div>

    <div class="mb-3">
      <input 
        class="form-control" 
        name="listing[country]" 
        placeholder="Country" 
        required
      >
    </div>

    <div class="mb-3">
      <input 
        class="form-control" 
        name="listing[location]" 
        placeholder="Location" 
        required
      >
    </div>

    <button class="btn btn-primary">Add</button>

  </form>
</div>