<% layout('layouts/boilerplate') %>
<!DOCTYPE html>
<html>
<head>
  <title>New Listing</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container mt-4">
  <h3>Create New Listing</h3>

  <form method="POST" action="/listings">

    <div class="mb-3">
      <input class="form-control" name="listing[title]" placeholder="Title">
    </div>

    <div class="mb-3">
      <textarea class="form-control" name="listing[description]" placeholder="Description"></textarea>
    </div>

    <div class="mb-3">
      <input class="form-control" name="listing[image]" placeholder="Image URL">
    </div>

    <div class="mb-3">
      <input class="form-control" type="number" name="listing[price]" placeholder="Price">
    </div>

    <div class="mb-3">
      <input class="form-control" name="listing[country]" placeholder="Country">
    </div>

    <div class="mb-3">
      <input class="form-control" name="listing[location]" placeholder="Location">
    </div>

    <button class="btn btn-primary">Add</button>

  </form>
</div>

</body>
</html>